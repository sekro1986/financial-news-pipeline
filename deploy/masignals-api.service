[Unit]
Description=MA-Signals API (FastAPI)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/financial-news-pipeline
EnvironmentFile=/opt/financial-news-pipeline/.env
ExecStart=/opt/financial-news-pipeline/.venv/bin/uvicorn ma_signals.api:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10
User=masignals

[Install]
WantedBy=multi-user.target
