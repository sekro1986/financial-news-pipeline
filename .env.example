# ============ MA-Signals : configuration ============
# Copier en .env et adapter :  cp .env.example .env

# --- Identité réseau : OBLIGATOIRE pour la SEC (mets un vrai email) ---
USER_AGENT=MASignals/1.0 (contact: ton-email@example.com)

# --- Base de données ---
# En Docker, docker-compose surcharge automatiquement vers Postgres.
# En local hors Docker, SQLite par défaut suffit :
# DATABASE_URL=sqlite:///./ma_signals.db
POSTGRES_PASSWORD=change-me-strong-password

# --- Cadence & seuils ---
POLL_INTERVAL_SECONDS=300
# Seuil global par defaut (les seuils PAR FAMILLE du code s'appliquent ensuite ;
# surcharge fine possible via FAMILY_THRESHOLDS en JSON) :
ALERT_MIN_SCORE=8

# --- Sources activées (CSV) ---
# ATTENTION : cette variable FIGE la liste et ecrase le defaut du code.
# Laisser commentee pour suivre les nouvelles sources ajoutees par les mises a jour.
# ENABLED_SOURCES=sec_edgar,rns_uk,amf_france,press_rss,rss_custom,disclosures,prices,adhoc_ir,screener,mfn

# --- Enrichissement LLM (Claude Haiku) : laisser vide pour désactiver ---
# Pour les items qui franchissent le pré-filtre regex, un appel LLM extrait :
# société cible, acquéreur, type d'événement et sens attendu du cours (fiabilise
# l'extraction, la dedup cross-langue et les verdicts du rapport d'impact).
# Clé : https://console.anthropic.com (coût indicatif : quelques centimes/jour).
# LLM_ENABLED=true
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5
# LLM_MIN_SCORE=4            # pré-score regex minimal pour mériter un appel
# LLM_MAX_PER_CYCLE=80       # budget d'appels par cycle
# LLM_CONFIDENCE_FLOOR=60    # sous ce niveau, l'avis LLM est ignoré

# --- Alerting Telegram (laisser vide pour désactiver) ---
# 1) Crée un bot via @BotFather -> récupère le token
# 2) Récupère ton chat_id (parle au bot puis https://api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Sauvegarde & healthcheck (timers systemd, voir DEPLOY.md) ---
# BACKUP_DIR=./backups
# BACKUP_KEEP=14
# HEARTBEAT_STALE_MINUTES=30
# MONITORED_SOURCES=sec_edgar,rns_uk,press_rss,mfn
# SOURCE_SILENCE_HOURS=24

# --- API REST : clé d'accès (vide = ouverte, OK seulement en 127.0.0.1) ---
# Si définie, tous les endpoints sauf /health exigent l'en-tête X-API-Key.
# Générer : openssl rand -hex 32
# API_KEY=

# --- Alerting Slack (laisser vide pour désactiver) ---
# Crée une "Incoming Webhook" dans ton workspace Slack
SLACK_WEBHOOK_URL=


# --- Flux RSS personnalises (rss.app : X/Twitter, blogs, newsletters) ---
# METHODE RECOMMANDEE : edite le fichier dedie feeds.txt (1 URL par ligne).
#   cp feeds.txt.example feeds.txt   puis edite-le.
# RSS_CUSTOM_FEEDS_FILE=feeds.txt    # chemin du fichier (defaut: feeds.txt)
# RSS_CUSTOM_FEEDS=                  # alternative/complement en CSV (optionnel)
CURATED_SCORE_BONUS=2               # bonus de score pour ces sources curees

# --- Watchlist optionnelle (CSV de noms/tickers). Vide = tout le marché ---
# WATCHLIST=easyjet,boeing,vodafone
WATCHLIST=
